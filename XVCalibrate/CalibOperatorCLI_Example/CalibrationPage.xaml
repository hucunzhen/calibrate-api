<Page x:Class="CalibOperatorCLI_Example.CalibrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="圆点标定">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <!-- 窄屏时自动换行 -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,10">
            <Button x:Name="BtnGenerateImage" Content="① 生成标定图" MinWidth="130" Height="32" Margin="0,0,8,8" Padding="10,0" Click="BtnGenerateImage_Click"
                    ToolTip="生成九宫格圆点标定图案"/>
            <Button x:Name="BtnLoadImage" Content="② 加载图像" MinWidth="120" Height="32" Margin="0,0,8,8" Padding="10,0" Click="BtnLoadImage_Click"
                    ToolTip="从文件加载 BMP 等图像"/>
            <Button x:Name="BtnGrabImage" Content="③ 相机采图" MinWidth="120" Height="32" Margin="0,0,8,8" Padding="10,0" Click="BtnGrabImage_Click" ToolTip="从相机采集一帧图像"/>
            <Button x:Name="BtnConnectCamera" Content="连接相机" MinWidth="100" Height="32" Margin="0,0,8,8" Padding="10,0" Click="BtnConnectCamera_Click" ToolTip="连接或断开相机"/>
            <Button x:Name="BtnDetectCircles" Content="④ 检测圆点" MinWidth="120" Height="32" Margin="0,0,8,8" Padding="10,0" Click="BtnDetectCircles_Click"
                    ToolTip="检测标定圆并提取圆心"/>
            <Button x:Name="BtnCalibrate" Content="⑤ 执行标定" MinWidth="120" Height="32" Margin="0,0,8,8" Padding="10,0" Click="BtnCalibrate_Click"
                    ToolTip="根据图像点与世界点求解仿射变换"/>
            <Button x:Name="BtnSaveResults" Content="⑥ 保存结果" MinWidth="120" Height="32" Margin="0,0,8,8" Padding="10,0" Click="BtnSaveResults_Click"
                    ToolTip="保存标定矩阵等到文件"/>
            <Button x:Name="BtnTestTransform" Content="⑦ 验证变换" MinWidth="120" Height="32" Margin="0,0,8,8" Padding="10,0" Click="BtnTestTransform_Click"
                    ToolTip="使用当前变换测试像素→世界坐标"/>
            <Button x:Name="BtnAutoTrajTest" Content="⑧ 自动轨迹测试" MinWidth="140" Height="32" Margin="0,0,8,8" Padding="10,0" Click="BtnAutoTrajTest_Click"
                    ToolTip="自动运行轨迹相关测试流程"/>
        </WrapPanel>

        <!-- Image display -->
        <Border Grid.Row="1" BorderBrush="Black" BorderThickness="1" Background="Black" Margin="0,0,0,10"
                ClipToBounds="True">
            <ScrollViewer x:Name="ImageScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel"
                          PreviewMouseDown="ImageScrollViewer_PreviewMouseDown"
                          PreviewMouseMove="ImageScrollViewer_PreviewMouseMove"
                          PreviewMouseUp="ImageScrollViewer_PreviewMouseUp"
                          PreviewMouseRightButtonUp="ImageScrollViewer_PreviewMouseRightButtonUp">
                <Image x:Name="ImageDisplay"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="保存图片" Click="SaveImage_Click"/>
                        </ContextMenu>
                    </Image.ContextMenu>
                    <Image.LayoutTransform>
                        <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1" ScaleY="1"/>
                    </Image.LayoutTransform>
                </Image>
            </ScrollViewer>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#2D2D30" Padding="8,6" Margin="0,0,0,10" BorderBrush="#3F3F46" BorderThickness="1">
            <TextBlock x:Name="StatusText" Text="就绪" Foreground="#CCCCCC" VerticalAlignment="Center"/>
        </Border>

        <!-- Log -->
        <TextBox x:Name="LogTextBox" Grid.Row="3"
                 IsReadOnly="True"
                 FontFamily="Consolas" FontSize="11"
                 VerticalScrollBarVisibility="Auto"
                 Background="#1E1E1E" Foreground="#90EE90"
                 AcceptsReturn="True" TextWrapping="Wrap"/>
    </Grid>
</Page>
