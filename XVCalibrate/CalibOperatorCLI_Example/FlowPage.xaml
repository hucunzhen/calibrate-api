<Page x:Class="CalibOperatorCLI_Example.FlowPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="组态流程">
    <Grid Background="#252526">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" MinWidth="180"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧：算子工具箱 -->
        <Border Grid.Column="0" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,1,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="算子工具箱" Foreground="#CCCCCC"
                           FontSize="14" FontWeight="Bold" Margin="10,10,10,5"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="OperatorToolbox" Margin="4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander IsExpanded="{Binding IsExpanded}" Margin="0,6,0,0"
                                          Background="#2B2B2E" Foreground="#CCCCCC">
                                    <Expander.Header>
                                        <Border Background="#303033" CornerRadius="4" Padding="6,4">
                                            <TextBlock Text="{Binding Name}" Foreground="#9CDCFE" FontSize="12" FontWeight="Bold"/>
                                        </Border>
                                    </Expander.Header>
                                    <ItemsControl ItemsSource="{Binding Operators}" Margin="0,4,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#2D2D30" BorderBrush="#3C3C3C" BorderThickness="1"
                                                        CornerRadius="4" Margin="0,0,0,3" Padding="8,6"
                                                        MouseLeftButtonDown="OperatorItem_MouseLeftButtonDown"
                                                        Cursor="Hand">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding DisplayName}" Foreground="#DCDCDC"
                                                                   FontSize="12" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Description}" Foreground="#858585"
                                                                   FontSize="10" Margin="0,2,0,0"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- GridSplitter -->
        <GridSplitter Grid.Column="1" Width="4" Background="#3C3C3C"
                      HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

        <!-- 右侧：组态画布 -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="120" MinHeight="60"/>
            </Grid.RowDefinitions>

            <!-- 工具栏 -->
            <Border Grid.Row="0" Background="#2D2D2D" Padding="8,4" BorderBrush="#3C3C3C"
                    BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <Button Content="&#xE74E;" FontFamily="Segoe MDL2 Assets" Width="32" Height="28"
                            ToolTip="全部运行" Background="#2D2D2D" Foreground="White"
                            BorderThickness="0" Click="RunAll_Click"/>
                    <Button x:Name="StopRunButton" Content="&#xE71A;" FontFamily="Segoe MDL2 Assets" Width="32" Height="28"
                            ToolTip="停止执行" Background="#2D2D2D" Foreground="#FFB3B3"
                            BorderThickness="0" Margin="4,0,0,0" Click="StopRun_Click" IsEnabled="False"/>
                    <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" Width="32" Height="28"
                            ToolTip="清空画布" Background="#2D2D2D" Foreground="White"
                            BorderThickness="0" Margin="4,0,0,0" Click="ClearCanvas_Click"/>
                    <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" Width="32" Height="28"
                            ToolTip="自动布局" Background="#2D2D2D" Foreground="White"
                            BorderThickness="0" Margin="4,0,0,0" Click="AutoLayout_Click"/>
                    <Separator Width="1" Background="#555" Margin="8,2"/>
                    <Button Content="&#xE74E;" FontFamily="Segoe MDL2 Assets" Width="32" Height="28"
                            ToolTip="保存组态" Background="#2D2D2D" Foreground="#90EE90"
                            BorderThickness="0" Click="SaveFlow_Click"/>
                    <Button Content="&#xE8E5;" FontFamily="Segoe MDL2 Assets" Width="32" Height="28"
                            ToolTip="加载组态" Background="#2D2D2D" Foreground="#90EE90"
                            BorderThickness="0" Margin="4,0,0,0" Click="LoadFlow_Click"/>
                    <Separator Width="1" Background="#555" Margin="8,2"/>
                    <TextBlock x:Name="StatusText" Text="就绪" Foreground="#9CDCFE"
                               VerticalAlignment="Center" FontSize="12" Margin="4,0,0,0"/>
                    <TextBlock Text="（图标按钮悬停查看说明）" Foreground="#858585" VerticalAlignment="Center"
                               FontSize="11" Margin="12,0,0,0"/>
                    <Separator Width="1" Background="#555" Margin="8,2"/>
                    <Button Content="&#xE8B9;" FontFamily="Segoe MDL2 Assets" Width="32" Height="28"
                            ToolTip="清空日志" Background="#2D2D2D" Foreground="#AAA"
                            BorderThickness="0" Margin="4,0,0,0" Click="ClearLog_Click"/>
                </StackPanel>
            </Border>

            <!-- 画布 -->
            <Canvas Grid.Row="1" x:Name="FlowCanvas" Background="#1E1E1E"
                    AllowDrop="True"
                    DragOver="FlowCanvas_DragOver"
                    Drop="FlowCanvas_Drop"
                    MouseLeftButtonDown="FlowCanvas_MouseLeftButtonDown"
                    MouseMove="FlowCanvas_MouseMove"
                    MouseLeftButtonUp="FlowCanvas_MouseLeftButtonUp"
                    MouseRightButtonDown="FlowCanvas_MouseRightButtonDown"
                    MouseRightButtonUp="FlowCanvas_MouseRightButtonUp"
                    MouseWheel="FlowCanvas_MouseWheel">
                <Canvas.Resources>
                    <Style TargetType="Path">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="StrokeThickness" Value="3"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Canvas.Resources>
            </Canvas>

            <!-- 日志分隔线 -->
            <GridSplitter Grid.Row="2" Height="3" Background="#3C3C3C"
                          HorizontalAlignment="Stretch" VerticalAlignment="Center"/>

            <!-- 日志区域：可选择的 TextBox 方便复制 -->
            <TextBox x:Name="LogBox" Grid.Row="3"
                     IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     Background="#1E1E1E" Foreground="#CCCCCC" BorderThickness="0"
                     FontFamily="Consolas" FontSize="11" Padding="6,4"
                     Text="就绪"/>
        </Grid>
    </Grid>
</Page>
