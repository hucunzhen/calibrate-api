<Window x:Class="CalibOperatorCLI_Example.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="工业视觉标定工具"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow">
    <Window.Resources>
        <SolidColorBrush x:Key="NavBarBrush" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="NavHoverBrush" Color="#404040"/>
        <SolidColorBrush x:Key="NavAccentBrush" Color="#007ACC"/>
        <Style x:Key="NavTabButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="{StaticResource NavBarBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="{StaticResource NavHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="{StaticResource NavAccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource NavBarBrush}" Padding="0">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="NavCalibration" Content="标定" Style="{StaticResource NavTabButtonStyle}"
                        Click="NavCalibration_Click"
                        AutomationProperties.Name="标定"/>
                <Button x:Name="NavTrajectory" Content="轨迹检测" Style="{StaticResource NavTabButtonStyle}"
                        Click="NavTrajectory_Click"
                        AutomationProperties.Name="轨迹检测"/>
                <Button x:Name="NavPlc" Content="PLC" Style="{StaticResource NavTabButtonStyle}"
                        Click="NavPlc_Click"
                        AutomationProperties.Name="PLC"/>
                <Button x:Name="NavHistogram" Content="直方图" Style="{StaticResource NavTabButtonStyle}"
                        Click="NavHistogram_Click"
                        AutomationProperties.Name="直方图"/>
                <Button x:Name="NavFlow" Content="组态" Style="{StaticResource NavTabButtonStyle}"
                        Click="NavFlow_Click"
                        AutomationProperties.Name="组态流程"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Top" Height="2">
            <Border.Background>
                <SolidColorBrush x:Name="ActiveTabLine" Color="#007ACC"/>
            </Border.Background>
        </Border>

        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
    </DockPanel>
</Window>
