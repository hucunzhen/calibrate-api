<Window x:Class="CalibOperatorCLI_Example.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calibration GUI - 9-Point Calibration Tool"
        Height="900" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <!-- Row 0: First row of buttons -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="BtnGenerateImage" Content="1. Generate Image" Width="150" Height="32" Margin="0,0,10,0" Click="BtnGenerateImage_Click"/>
            <Button x:Name="BtnLoadImage" Content="2. Load Image" Width="150" Height="32" Margin="0,0,10,0" Click="BtnLoadImage_Click"/>
            <Button x:Name="BtnDetectCircles" Content="3. Detect Circles" Width="150" Height="32" Margin="0,0,10,0" Click="BtnDetectCircles_Click"/>
            <Button x:Name="BtnCalibrate" Content="4. Calibrate" Width="150" Height="32" Click="BtnCalibrate_Click"/>
        </StackPanel>

        <!-- Row 1: Second row of buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="BtnSaveResults" Content="5. Save Results" Width="150" Height="32" Margin="0,0,10,0" Click="BtnSaveResults_Click"/>
            <Button x:Name="BtnTestTransform" Content="6. Test Transform" Width="150" Height="32" Margin="0,0,10,0" Click="BtnTestTransform_Click"/>
            <Button x:Name="BtnTestImage" Content="7. TestImage" Width="150" Height="32" Margin="0,0,10,0" Click="BtnTestImage_Click"/>
            <Button x:Name="BtnAutoTrajTest" Content="8. AutoTrajTest" Width="150" Height="32" Click="BtnAutoTrajTest_Click"/>
        </StackPanel>

        <!-- Row 2: Image display -->
        <Border Grid.Row="2" BorderBrush="Black" BorderThickness="1" Background="Black" Margin="0,0,0,10">
            <Image x:Name="ImageDisplay" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
        </Border>

        <!-- Row 3: Status bar -->
        <Border Grid.Row="3" Background="#E0E0E0" Padding="5" Margin="0,0,0,10">
            <TextBlock x:Name="StatusText" Text="Ready - Click buttons to start" VerticalAlignment="Center"/>
        </Border>

        <!-- Row 4: Log text box -->
        <TextBox x:Name="LogTextBox" Grid.Row="4" 
                 IsReadOnly="True" 
                 FontFamily="Consolas" FontSize="11"
                 VerticalScrollBarVisibility="Auto"
                 Background="#1E1E1E" Foreground="#90EE90"
                 AcceptsReturn="True" TextWrapping="Wrap"/>
    </Grid>
</Window>